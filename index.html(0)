<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Insight - Party Game Engine</title>
    <script src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
    <link rel="stylesheet" href="style.css">
</head>
<body>
<div class="app-container">
<div class="game-window">

    <div class="screen active" id="scrMenu" style="justify-content: center;">
        <div class="brand-header">
            <div class="brand-title">INSIGHT</div>
            <div class="brand-subtitle">Party Game Engine</div>
        </div>
        <input type="text" class="input-field" id="menuNameInput"
            placeholder="Your Nickname" maxlength="12" style="text-align:center;">
        <button class="btn-main" onclick="createLiveRoom()">Host New Game</button>
        <button class="btn-secondary" onclick="showScreen('scrJoin')">Join a Room</button>
    </div>

    <div class="screen" id="scrJoin" style="justify-content: center;">
        <div class="brand-header">
            <div class="brand-title">JOIN</div>
            <div class="brand-subtitle">Enter the Room ID your host shared</div>
        </div>
        <input type="text" class="input-field room-code-input" id="joinRoomInput"
            placeholder="XXXX" maxlength="4">
        <button class="btn-main" onclick="joinLiveRoom()">Connect to Lobby</button>
        <button class="btn-secondary" onclick="showScreen('scrMenu')">Back</button>
    </div>

    <div class="screen" id="scrLobby">
        <div class="brand-header">
            <div class="brand-title">LOBBY</div>
            <div class="brand-subtitle">Share the Room ID with your group</div>
        </div>

        <div class="room-code-display" id="lobbyIdLabel">⌛</div>
        <p class="lobby-status" id="lobbyStatusLabel">1 / 3 players — need 2 more</p>

        <div id="lobbyPlayerGrid" style="text-align:center;"></div>

        <div id="hostOnlyControls" style="display:none;">
            <div class="section-label" style="margin-top:6px;">SELECT CATEGORY DECK:</div>
            <div class="deck-grid">
                <div class="deck-pill" onclick="setCategory('classic',this)">🎭 Classic</div>
                <div class="deck-pill" onclick="setCategory('trouble',this)">⚡ Trouble</div>
                <div class="deck-pill active" onclick="setCategory('spicy',this)">🌶️ Spicy</div>
                <div class="deck-pill" onclick="setCategory('deep',this)">🧠 Deep</div>
                <div class="deck-pill" onclick="setCategory('hooot',this)">🔥 Hooot</div>
                <div class="deck-pill" onclick="setCategory('trash',this)">🗑️ Trash</div>
                <div class="deck-pill" onclick="confirmNSFW(this)">🔞 NSFW</div>
                <div class="deck-pill" onclick="setCategory('misc',this)">🎲 Mixed Decks</div>
            </div>

            <div class="section-label" style="margin-top:14px;">GAME LENGTH:</div>
            <div class="round-grid">
                <div class="round-pill active" onclick="setMaxRounds(10,this)">10 rounds</div>
                <div class="round-pill" onclick="setMaxRounds(30,this)">30 rounds</div>
                <div class="round-pill" onclick="setMaxRounds(45,this)">45 rounds</div>
                <div class="round-pill" onclick="setMaxRounds('unlimited',this)">Unlimited</div>
            </div>

            <button class="btn-secondary" onclick="addTestBots()" style="margin-top: 14px; width: 100%; border-color: var(--accent-blue); color: var(--text-primary);">➕ Add Test Bots</button>
        </div>

        <button class="btn-main" id="hostStartBtn" style="display:none; margin-top:auto;"
            onclick="broadcastStartRound()">Start Game</button>
        <p class="sub-track" id="clientWaitNotice" style="display:none; padding:10px 0;">
            Waiting for host to start the game...
        </p>
        <button class="btn-secondary" onclick="triggerLeaveConfirmation()" style="margin-top: 8px;">Leave Room</button>
    </div>

    <div class="screen" id="scrSubjectLounge">
        <div class="brand-header">
            <div class="brand-title" style="font-size:26px;">You're the Target 🎯</div>
            <div class="brand-subtitle">Players are writing about you...</div>
        </div>
        <div class="prompt-box" style="margin-bottom: 8px;">
            <div class="prompt-text" id="subjectPromptLabel" style="font-size: 15px;">...</div>
        </div>
        <div class="timer-display" id="subjectTimerLabel">0:45</div>
        <div class="fidget-board">
            <div class="fidget-toy"><div class="clicker-btn" id="toyClicker">0</div></div>
            <div class="fidget-toy"><div class="switch-track" id="toyToggle"><div class="switch-handle"></div></div></div>
            <div class="fidget-toy" style="grid-column: span 2;"><div class="bubble-grid" id="toyBubbleGrid"></div></div>
        </div>
        <div class="sub-track" id="submissionTrackLabel">0 cards locked in...</div>
        <button class="btn-secondary" onclick="triggerLeaveConfirmation()" style="margin-top: auto;">Leave Game</button>
    </div>

    <div class="screen" id="scrWriterInput">
        <div class="brand-header">
            <div class="brand-title" style="font-size:22px; color:var(--accent-red);" id="writerCategoryLabel">SPICY</div>
        </div>
        <div class="prompt-box">
            <div class="prompt-text" id="activePromptLabel">...</div>
        </div>
        <div class="timer-display" id="writerTimerLabel">0:45</div>
        <textarea class="input-field" id="writerInput"
            placeholder="Type your answer..."
            rows="2"
            style="resize:none; min-height:52px; max-height:100px; overflow-y:auto; word-break:break-word; overflow-wrap:break-word;"></textarea>
        <div style="text-align:right; font-size:11px; color:var(--text-secondary); margin-top:-8px;" id="charCount">0 / 120 words</div>
        <button class="btn-main" id="lockInBtn" onclick="submitWriterCard()">Lock In Card</button>
        <button class="btn-secondary" onclick="triggerLeaveConfirmation()" style="margin-top: 12px;">Leave Game</button>
    </div>

    <div class="screen" id="scrRevealStage">
        <div class="brand-header">
            <div class="brand-title" style="font-size:26px;">The Reveal</div>
            <div class="brand-subtitle" id="revealInstructions">...</div>
        </div>
        <div class="prompt-box">
            <div class="prompt-text" id="revealPromptLabel">...</div>
        </div>
        <div class="cards-stack" id="cardsWrapper"></div>
        <button class="btn-main" id="nextRoundBtn" style="display:none; margin-top:auto;"
            onclick="broadcastStartRound()">Next Round</button>
        <button class="btn-secondary" onclick="triggerLeaveConfirmation()" style="margin-top: 12px;">Leave Game</button>
    </div>

</div>

<div class="modal-overlay" id="confirmLeaveModal">
    <div class="modal-card">
        <div class="modal-title">Abandon Match?</div>
        <div class="modal-desc">Are you sure you want to exit? You will disconnect from your group and lose current progress.</div>
        <div class="modal-actions">
            <button class="btn-secondary" style="margin:0;" onclick="dismissLeaveConfirmation()">Cancel</button>
            <button class="btn-main" style="margin:0; padding: 14px;" onclick="confirmLeaveRoom()">Leave</button>
        </div>
    </div>
</div>

</div>

<script src="game.js"></script>
</body>
</html>
